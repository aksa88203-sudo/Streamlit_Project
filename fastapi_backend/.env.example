APP_NAME=FastAPI CRUD Service
APP_ENV=development
API_V1_PREFIX=/api/v1
APP_DEBUG=true
AUTO_CREATE_TABLES=true

MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_DB=inventory_db
MYSQL_CHARSET=utf8mb4
MYSQL_ROOT_PASSWORD=root_password

# Example:
# mysql+pymysql://app_user:app_password@localhost:3306/inventory_db?charset=utf8mb4
DATABASE_URL=
